{
  "$schema": "https://opencode.ai/config.json",

  // Claude-Mem OpenCode Configuration
  // Enables persistent memory across coding sessions.
  //
  // The plugin at .opencode/plugin/claude-mem.ts is auto-loaded by OpenCode.
  // MCP tools below provide in-session memory search via the claude-mem worker.
  //
  // Quick-start:
  //   npm run worker:start   (from the claude-mem directory)
  //   opencode               (in any project directory)

  // Instructions injected into every system prompt
  "instructions": [
    ".opencode/instructions/claude-mem.md"
  ],

  // MCP server integration – gives the AI search/timeline/observation tools
  "mcp": {
    "claude-mem": {
      "type": "stdio",
      "command": "node",
      "args": ["plugin/scripts/mcp-server.cjs"]
    }
  }
}
